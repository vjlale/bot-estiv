# ===== Core =====
APP_ENV=development
APP_NAME=bot-estiv
LOG_LEVEL=INFO
TENANT_ID=gardens-wood

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bot_estiv
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/bot_estiv

# ===== Redis / ARQ =====
REDIS_URL=redis://localhost:6379/0

# ===== LLM provider (Gemini-only stack) =====
# Generá la key en https://aistudio.google.com/apikey
GOOGLE_API_KEY=...
# Modelo de texto/razonamiento (económico + smart)
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Generación de imágenes (Nano Banana 2)
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Embeddings para RAG del manual de marca (768 dims = económico y suficiente)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# ===== Twilio WhatsApp =====
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+5491112345678  # dueño / aprobador por defecto

# ===== Meta (Facebook / Instagram) =====
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_xxxxxxxx
META_IG_BUSINESS_ID=
META_FB_PAGE_ID=
META_API_VERSION=v19.0

# ===== Media storage (S3 / R2) =====
S3_ENDPOINT_URL=
S3_REGION=auto
S3_BUCKET=bot-estiv-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://media.bot-estiv.local

# ===== Brand assets =====
BRAND_LOGO_PATH=../../Branding/LOGOCOMPLETO.png
BRAND_MANUAL_PATH=../../Branding/Manual de Identidad de Marca_ Gardens Wood.txt

# ===== Figma (plantillas de overlay como fuente de verdad) =====
# Generar token en https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=figd_...
# File key = parte de la URL de Figma entre /file/ o /design/ y el nombre
# ej: https://www.figma.com/design/ABC123xyz/Bot-Estiv  → ABC123xyz
FIGMA_TEMPLATES_FILE_KEY=

# ===== Monitoring =====
SENTRY_DSN=

# ===== API base URL (used by dashboard) =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
