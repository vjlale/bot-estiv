# ===== Hostinger VPS =====
# Copiar este archivo a .env en la carpeta bot-estiv interna del VPS.
APP_ENV=production
APP_NAME=bot-estiv
LOG_LEVEL=INFO
TENANT_ID=gardens-wood

# Dominios publicos
BOT_ESTIV_DASHBOARD_DOMAIN=bot-estiv.gardenswood.com.ar
BOT_ESTIV_API_DOMAIN=api.bot-estiv.gardenswood.com.ar
NEXT_PUBLIC_API_BASE_URL=https://api.bot-estiv.gardenswood.com.ar

# Rutas del servidor
BOT_ESTIV_APP_DIR=/opt/bot-estiv/app/bot-estiv
BOT_ESTIV_BRANDING_DIR=/opt/bot-estiv/branding
BOT_ESTIV_BACKUP_DIR=/opt/bot-estiv/backups
BOT_ESTIV_LETSENCRYPT_EMAIL=admin@gardenswood.com.ar

# ===== Database =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-use-a-long-password
POSTGRES_DB=bot_estiv
DATABASE_URL=postgresql+asyncpg://postgres:change-me-use-a-long-password@postgres:5432/bot_estiv
DATABASE_URL_SYNC=postgresql://postgres:change-me-use-a-long-password@postgres:5432/bot_estiv

# ===== Redis / ARQ =====
REDIS_URL=redis://redis:6379/0

# ===== LLM provider (Gemini-only stack) =====
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# ===== Twilio WhatsApp =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+5491112345678

# ===== Meta (Facebook / Instagram) =====
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_xxxxxxxx
META_IG_BUSINESS_ID=
META_FB_PAGE_ID=
META_API_VERSION=v19.0

# ===== Media storage (S3 / R2) =====
S3_ENDPOINT_URL=
S3_REGION=auto
S3_BUCKET=bot-estiv-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ===== Brand assets mounted into API/worker containers =====
BRAND_LOGO_PATH=/branding/LOGOCOMPLETO.png
BRAND_MANUAL_PATH=/branding/Manual de Identidad de Marca_ Gardens Wood.txt

# ===== Figma =====
FIGMA_ACCESS_TOKEN=
FIGMA_TEMPLATES_FILE_KEY=

# ===== Monitoring =====
SENTRY_DSN=
